# ============================================================================
# FinSaarthi — Environment Variables
# ============================================================================

# 1. AI & LLM (Required for Agents)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# 2. Database & State (Storage)
# Default is in the current project directory
AUDIT_DB_PATH=./data/finsaarthi_audit.db

# 3. RAG & Knowledge Base (M3 territory)
CHROMA_PATH=./chromadb_store
KNOWLEDGE_BASE_READY=true

# 4. API & Port Configuration
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173

# 5. Logging Level
LOG_LEVEL=INFO
